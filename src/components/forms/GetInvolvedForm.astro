---
import { Button, FormInput, FormTextarea } from '@components/odyssey-theme';
import settings from '../../config/settings';

const WEB3FORMS_ACCESS_KEY = 'f5d55072-cd59-41f7-98b0-6df69812126d';
---

<form
	id="get-involved-form"
	name="Get Involved Contact Form"
	method="POST"
	action="https://api.web3forms.com/submit"
>
	<input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
	<input type="hidden" name="subject" value="AI4Science Club - Get Involved Form Submission" />
	<input type="hidden" name="from_name" value="AI4Science Get Involved Form" />
	<input type="hidden" name="redirect" value={`${settings.url}/get-involved/thanks`} />
	<input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden-field" />

	<FormInput
		type="text"
		label="Name"
		name="name"
		placeholder="Your full name"
		required
	/>
	<FormInput
		type="email"
		label="Email address"
		name="email"
		placeholder="you@domain.com"
		required
	/>
	<FormTextarea
		label="Message"
		name="message"
		placeholder="How would you like to get involved?"
		rows={6}
		required
	/>

	<div class="form-footer">
		<Button>
			<span class="btn-label" data-default="Send message">Send message</span>
		</Button>
		<p class="form-status" role="status" aria-live="polite"></p>
	</div>
</form>

<style>
	form {
		display: grid;
		gap: 0.85rem;
	}

	.hidden-field {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	.form-footer {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.25rem;
	}

	.form-status {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.3;
		color: var(--theme-on-surface-1);
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.form-status[data-state="success"],
	.form-status[data-state="error"],
	.form-status[data-state="sending"] {
		opacity: 1;
		transform: translateX(0);
	}

	.form-status[data-state="error"] {
		color: #c0392b;
	}

	.form-status[data-state="success"] {
		color: var(--theme-primary);
		font-weight: 500;
	}

	.form-footer :global(.btn[disabled]) {
		opacity: 0.7;
		cursor: default;
	}
</style>

<script>
	const form = document.getElementById('get-involved-form') as HTMLFormElement | null;
	if (form) {
		const button = form.querySelector('button.btn') as HTMLButtonElement | null;
		const label = form.querySelector('.btn-label') as HTMLSpanElement | null;
		const status = form.querySelector('.form-status') as HTMLParagraphElement | null;
		const fields = form.querySelectorAll('input, textarea, button') as NodeListOf<
			HTMLInputElement | HTMLTextAreaElement | HTMLButtonElement
		>;

		if (button && label && status) {
			const defaultLabel = label.dataset.default ?? label.textContent ?? 'Send message';

			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				button.disabled = true;
				label.textContent = 'Sending…';
				status.textContent = '';
				status.dataset.state = 'sending';

				try {
					const response = await fetch('https://api.web3forms.com/submit', {
						method: 'POST',
						headers: { Accept: 'application/json' },
						body: new FormData(form),
					});
					const data = await response.json().catch(() => ({}));

					if (!response.ok || !data?.success) {
						throw new Error(data?.message ?? 'Submission failed');
					}

					label.textContent = 'Sent!';
					status.textContent = 'Thanks! We will get back to you by email.';
					status.dataset.state = 'success';
					fields.forEach((field) => {
						field.disabled = true;
					});
				} catch (error) {
					console.error('Get involved form submission failed', error);
					button.disabled = false;
					label.textContent = defaultLabel;
					status.textContent =
						'Something went wrong. Please try again or email info@ai4science.ch.';
					status.dataset.state = 'error';
				}
			});
		}
	}
</script>
